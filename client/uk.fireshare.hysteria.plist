<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>uk.fireshare.hysteria</string>
    <key>ProgramArguments</key>
    <array>
        <string>/Users/<USERNAME>/bin/hysteria</string>
        <string>client</string>
        <string>--config</string>
        <string>/Users/<USERNAME>/Library/Application Support/hysteria/client.yaml</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/tmp/hysteria-mac.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/hysteria-mac.log</string>
</dict>
</plist>
